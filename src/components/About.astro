---
import { differentials } from '../data/site';
// Métricas desativadas por enquanto — reative descomentando `stats` em
// src/data/site.ts e o import + <Stats /> abaixo.
// import { stats } from '../data/site';
// import Stats from './Stats.tsx';
---

<section id="sobre" class="section about">
  <div class="container about__grid">
    <div class="about__intro">
      <span class="eyebrow" data-reveal>Sobre a Yerus</span>
      <h2 class="about__title" data-reveal data-reveal-delay="0.05">
        Não adianta ter uma excelente marca se as pessoas não <span class="gold-text">enxergam isso</span>
      </h2>

      <div class="about__cards">
        {
          differentials.map((d, i) => (
            <div class="about__card" data-reveal data-reveal-delay={0.06 * i}>
              <span class="about__card-bar" aria-hidden="true" />
              <div>
                <h3>{d.title}</h3>
                <p>{d.text}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <aside class="about__aside" data-reveal data-reveal-delay="0.12">
      <!-- <Stats stats={stats} client:visible /> -->
      <p class="about__note">
        Ninguém cresce sozinho. É exatamente isso que construiremos juntos, a partir de agora.
      </p>
    </aside>
  </div>
</section>

<style>
  .about {
    position: relative;
  }

  .about__grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }
  .about__title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    margin-top: 1.2rem;
  }
  .about__text {
    color: var(--muted);
    font-size: 1.08rem;
    margin-top: 1.4rem;
    max-width: 56ch;
  }

  .about__cards {
    margin-top: 2.6rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .about__card {
    display: flex;
    gap: 1.1rem;
    padding: 1.3rem 1.4rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.015);
    transition: border-color 0.4s var(--ease);
  }
  .about__card:hover {
    border-color: var(--line-strong);
  }
  .about__card-bar {
    flex: none;
    width: 3px;
    border-radius: 3px;
    background: var(--gold-gradient);
  }
  .about__card h3 {
    font-size: 1.3rem;
    margin-bottom: 0.3rem;
  }
  .about__card p {
    color: var(--muted);
    font-size: 0.94rem;
  }

  .about__aside {
    position: sticky;
    top: 100px;
  }
  .about__note {
    margin-top: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--white);
    line-height: 1.3;
  }

  @media (min-width: 980px) {
    .about__grid {
      grid-template-columns: 1.15fr 0.85fr;
      gap: 4rem;
    }
  }
</style>
