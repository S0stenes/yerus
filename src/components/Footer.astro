---
import { site, navLinks, whatsappLink, instagramLink, emailLink } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="rule"></div>
  <div class="container footer__inner">
    <div class="footer__brand">
      <img src="/logo-golden.svg" alt="Yerus" width="150" height="52" />
      <p>{site.tagline}</p>
    </div>

    <nav class="footer__nav" aria-label="Rodapé">
      <span class="footer__label">Navegação</span>
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="footer__contact">
      <span class="footer__label">Contato</span>
      <a href={whatsappLink} target="_blank" rel="noopener">WhatsApp</a>
      <a href={instagramLink} target="_blank" rel="noopener">Instagram</a>
      <a href={emailLink}>{site.contact.email}</a>
      <span class="footer__city">{site.contact.city}</span>
    </div>
  </div>

  <div class="container footer__bottom">
    <span>© {year} {site.name}. Todos os direitos reservados.</span>
    <span>Feito com estratégia e autenticidade.</span>
  </div>
</footer>

<style>
  .footer {
    padding-top: 3rem;
    background: var(--black);
  }
  .footer__inner {
    display: grid;
    gap: 2.4rem;
    padding-block: 3.4rem;
  }
  .footer__brand img {
    height: 42px;
    width: auto;
  }
  .footer__brand p {
    margin-top: 1rem;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--muted);
    font-size: 1.15rem;
  }
  .footer__label {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted-2);
    margin-bottom: 1rem;
  }
  .footer__nav,
  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer__nav a,
  .footer__contact a {
    color: var(--muted);
    font-size: 0.95rem;
    transition: color 0.3s var(--ease);
    width: fit-content;
  }
  .footer__nav a:hover,
  .footer__contact a:hover {
    color: var(--gold-1);
  }
  .footer__city {
    color: var(--muted-2);
    font-size: 0.9rem;
  }

  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: space-between;
    padding-block: 1.8rem;
    border-top: 1px solid var(--line);
    color: var(--muted-2);
    font-size: 0.82rem;
  }

  @media (min-width: 760px) {
    .footer__inner {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }
</style>
